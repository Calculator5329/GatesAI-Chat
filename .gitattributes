# Normalize line endings: store text as LF in the repo and check out LF on
# every platform, so Windows autocrlf no longer rewrites files to CRLF (which
# was producing whitespace-only diffs across machines).
* text=auto eol=lf

# Treat known binary assets as binary so Git never touches their bytes.
*.png    binary
*.jpg    binary
*.jpeg   binary
*.gif    binary
*.ico    binary
*.webp   binary
*.icns   binary
*.woff   binary
*.woff2  binary
*.ttf    binary
*.otf    binary
*.exe    binary
*.dll    binary
*.AppImage binary
