{
  "name": "gatesai-chat",
  "private": true,
  "version": "4.0.4",
  "description": "Local-first desktop AI chat workspace (React 19 + Tauri 2) with a sandboxed local bridge for files, shell, SQLite, git, web search, and image generation.",
  "homepage": "https://calculator5329.github.io/GatesAI-Chat/",
  "repository": {
    "type": "git",
    "url": "git+https://github.com/Calculator5329/GatesAI-Chat.git"
  },
  "type": "module",
  "scripts": {
    "dev": "vite",
    "source:snapshot": "node scripts/create-source-snapshot.mjs",
    "build": "tsc -b && vite build",
    "build:web": "tsc -b && vite build --mode firebase",
    "deploy:firebase": "npm run build:web && firebase deploy --only hosting",
    "analyze": "vite build --mode analyze --sourcemap",
    "lint": "eslint .",
    "typecheck": "tsc -b && tsc -p tsconfig.test.json --noEmit",
    "test": "vitest run --config vitest.config.ts",
    "test:watch": "vitest",
    "test:models": "vitest run --config vitest.live.config.ts",
    "test:e2e": "playwright test",
    "ci": "npm test && npm run typecheck && npm run lint",
    "preview": "vite preview",
    "tauri": "tauri",
    "tauri:dev": "tauri dev",
    "tauri:build": "npm run source:snapshot && tauri build"
  },
  "dependencies": {
    "highlight.js": "^11.11.1",
    "katex": "^0.16.45",
    "mermaid": "^11.14.0",
    "mobx": "^6.15.0",
    "mobx-react-lite": "^4.1.1",
    "react": "^19.2.5",
    "react-dom": "^19.2.5",
    "react-markdown": "^10.1.0",
    "rehype-highlight": "^7.0.2",
    "rehype-katex": "^7.0.1",
    "remark-gfm": "^4.0.1",
    "remark-math": "^6.0.0"
  },
  "devDependencies": {
    "@babel/core": "^7.29.0",
    "@eslint/js": "^9.39.4",
    "@playwright/test": "^1.60.0",
    "@rolldown/plugin-babel": "^0.2.3",
    "@tauri-apps/api": "^2.10.1",
    "@tauri-apps/cli": "^2.10.1",
    "@types/babel__core": "^7.20.5",
    "@types/node": "^24.12.2",
    "@types/react": "^19.2.14",
    "@types/react-dom": "^19.2.3",
    "@vitejs/plugin-react": "^6.0.1",
    "babel-plugin-react-compiler": "^1.0.0",
    "eslint": "^9.39.4",
    "eslint-import-resolver-typescript": "^4.4.5",
    "eslint-plugin-import": "^2.32.0",
    "eslint-plugin-mobx": "^0.0.14",
    "eslint-plugin-react-hooks": "^7.1.1",
    "eslint-plugin-react-refresh": "^0.5.2",
    "globals": "^17.5.0",
    "jsdom": "^25.0.1",
    "rollup-plugin-visualizer": "^7.0.1",
    "typescript": "~6.0.2",
    "typescript-eslint": "^8.58.2",
    "vite": "^8.0.9",
    "vitest": "^3.2.4"
  }
}
