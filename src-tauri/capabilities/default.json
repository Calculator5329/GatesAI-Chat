{
  "$schema": "../gen/schemas/desktop-schema.json",
  "identifier": "default",
  "description": "enables the default permissions",
  "windows": [
    "main"
  ],
  "permissions": [
    "core:default",
    "global-shortcut:default",
    "dialog:default",
    {
      "identifier": "shell:allow-execute",
      "allow": [
        {
          "name": "binaries/gatesai-bridge",
          "sidecar": true,
          "args": ["--listen", { "validator": "^127\\.0\\.0\\.1:\\d{2,5}$" }]
        }
      ]
    }
  ]
}
