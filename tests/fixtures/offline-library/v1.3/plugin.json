{
  "schema_version": 1,
  "id": "local.offline-library",
  "name": "Offline Library",
  "version": "1.3.0",
  "description": "Citation-first local datasets, retrieval benchmarks, and approved database catalog for GatesAI.",
  "transport": {
    "kind": "loopback_http",
    "base_url": "http://127.0.0.1:8892/api/v1",
    "backend_proxy_required_for_webviews": true,
    "network_required": false,
    "redirects": false,
    "max_response_bytes": 1000000
  },
  "capabilities": [
    "health",
    "sources.read",
    "search.read",
    "evaluations.read",
    "benchmarks.knowledge_arena.read",
    "profiles.read",
    "databases.catalog.read",
    "databases.public_schema.read"
  ],
  "safety": {
    "mutations": false,
    "arbitrary_sql": false,
    "arbitrary_paths": false,
    "private_databases_exposed": false,
    "restricted_databases_exposed": false,
    "public_schema_only": true,
    "raw_benchmark_answers_exposed": false,
    "evidence_passages_exposed": false,
    "citations_required": true
  },
  "data_contracts": {
    "knowledge_arena": {
      "endpoint": "/benchmarks/knowledge-arena",
      "fixture": "fixtures/knowledge-arena.json",
      "includes": [
        "run_metadata",
        "aggregate_summaries",
        "exact_cell_summaries",
        "confidence_intervals",
        "grounding_proxies",
        "split_latency",
        "errors"
      ],
      "excludes": [
        "raw_answers",
        "evidence_passages",
        "private_or_restricted_data",
        "filesystem_paths",
        "factual_hallucination_rate"
      ]
    },
    "profiles": {
      "endpoint": "/profiles",
      "source": "profiles.json",
      "selection_is_task_aware": true,
      "user_override_expected": true,
      "remote_fallback": false,
      "evidence_required": [
        "sample_size",
        "score_confidence_interval",
        "component_metrics",
        "split_latency",
        "error_count",
        "limitations"
      ]
    }
  },
  "openapi": "openapi.json",
  "activation_status": "host_ready_consumer_approved"
}
